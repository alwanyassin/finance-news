---
import { articles, timeAgo } from "../data/articles";
import SectionHeader from "./SectionHeader.astro";

const editorsPickBig = articles[7]!; // Example article for big card
const editorsPickSmall = articles.slice(8, 11);
const latestHeadlines = articles.slice(2, 8);
---

<section class="max-w-7xl mx-auto px-4 lg:px-6 py-10" aria-label="Editor's Picks and Latest Headlines">
  <div class="flex flex-col lg:flex-row gap-0">
    <!-- Left Column: Editor's Picks (matches Top Stories width) -->
    <div class="flex-1 lg:pr-5 pb-5 lg:pb-0">
      <div class="mb-4">
        <SectionHeader title="Editor's Picks" />
      </div>

      <!-- Featured Big Card -->
      <article class="group relative flex flex-col md:flex-row bg-nk-navy text-white overflow-hidden mb-6 hover:shadow-lg transition-shadow duration-300 md:h-[230px]">
        <div class="p-6 flex-1 flex flex-col justify-center order-2 md:order-1 md:w-[50%] border-t-4 border-t-nk-red md:border-t-0 md:border-l-4 md:border-l-nk-red">
          <span class="text-[0.65rem] font-bold uppercase tracking-widest text-nk-gold-light mb-2 lg:mb-3 text-center md:text-left block font-sans">BIG IN ASIA</span>
          <h3 class="text-2xl md:text-[1.5rem] font-bold leading-tight mb-3 lg:mb-4 text-center md:text-left font-display group-hover:text-nk-gray-200 transition-colors">
            <a href={`/article/${editorsPickBig.slug}`} class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">{editorsPickBig.title}</a>
          </h3>
          <p class="text-[0.8rem] md:text-sm text-white/80 leading-relaxed text-center md:text-left font-sans mx-auto md:mx-0 line-clamp-2 md:line-clamp-2">
            {editorsPickBig.excerpt}
          </p>
        </div>
        <div class="order-1 md:order-2 md:w-[50%] relative aspect-video md:aspect-auto overflow-hidden bg-white">
          <img
            src={`${editorsPickBig.image}?w=800&q=85&auto=format&fit=crop`}
            alt={editorsPickBig.imageAlt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            width="800"
            height="450"
          />
        </div>
      </article>

      <!-- 3 Vertical Cards Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-px bg-nk-gray-200">
        {
          editorsPickSmall.map((article, index) => (
            <article class={`group bg-white p-2.5 sm:p-3 flex flex-col relative ${index === 2 ? "col-span-2 sm:col-span-1 border-b border-nk-gray-200 sm:border-b-0" : ""}`} aria-label={article.title}>
              <a href={`/article/${article.slug}`} tabindex="-1" aria-hidden="true" class={`block mb-2 overflow-hidden bg-nk-gray-200 aspect-video ${index === 2 ? "hidden sm:block" : ""}`}>
                <img src={`${article.image}?w=400&q=80&auto=format&fit=crop`} alt={article.imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" width="400" height="225" />
              </a>
              <span class="category-tag mb-1 block">{article.category}</span>
              <h3 class="text-base sm:text-lg font-bold text-nk-gray-800 leading-snug mb-2 group-hover:text-nk-red transition-colors" style="font-family: 'Playfair Display', Georgia, serif;">
                <a href={`/article/${article.slug}`} class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">
                  {article.title}
                </a>
              </h3>
              <div class={`flex items-center gap-1 text-[0.62rem] text-nk-gray-500 font-sans mt-auto ${index === 2 ? "hidden sm:flex" : ""}`}>
                <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Updated {timeAgo(article.publishedAt)}</span>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Right Column: Latest Headlines (matches Widget Panel width) -->
    <div class="lg:w-[260px] xl:w-[280px] shrink-0 lg:pl-0 pt-8 lg:pt-0">
      <div class="bg-nk-gray-100 p-2 h-full border border-nk-gray-200">
        <div class="mb-4">
          <SectionHeader title="Latest Headlines" size="sm" />
        </div>

        <div class="flex flex-col divide-y divide-nk-gray-300">
          {
            latestHeadlines.map((article, index) => (
              <article class={`group relative ${index === latestHeadlines.length - 1 ? "pt-3.5 pb-0" : "py-3.5"}`}>
                <h4 class="font-body text-base font-medium text-nk-gray-800 leading-snug group-hover:text-nk-red transition-colors mb-2.5 line-clamp-2">
                  <a href={`/article/${article.slug}`} class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">
                    {article.title}
                  </a>
                </h4>
                <div class={`flex items-center text-[0.75rem] font-sans gap-1.5 ${index === 0 ? "text-nk-breaking font-medium" : "text-nk-gray-500"}`}>
                  <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>
                    {index === 0 ? "Updated " : ""}
                    {timeAgo(article.publishedAt)}
                  </span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

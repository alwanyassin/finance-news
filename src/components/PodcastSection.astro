---
import SectionHeader from "./SectionHeader.astro";
---

<section class="max-w-7xl mx-auto px-4 lg:px-6 py-6" aria-label="Podcast Player">
  <div class="mb-5">
    <SectionHeader title="Featured Podcast" />
  </div>

  <div class="bg-[#181818] text-white p-5 md:p-6 shadow-xl relative overflow-hidden group border border-zinc-800 rounded-sm">
    <!-- Spotify Logo (Top Right) -->
    <div class="absolute top-5 right-5 text-zinc-400 group-hover:text-white transition-colors duration-150">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424c-.18.295-.565.387-.86.207-2.377-1.454-5.37-1.783-8.892-.982-.336.076-.67-.135-.746-.47-.077-.337.135-.67.472-.747 3.847-.878 7.14-.5 9.817 1.137.295.18.387.563.207.857zm1.222-2.723c-.226.367-.707.487-1.074.26-2.72-1.672-6.87-2.157-10.077-1.182-.413.125-.85-.107-.975-.52-.125-.413.107-.85.52-.975 3.666-1.112 8.232-.57 11.346 1.343.366.226.486.707.26 1.074zm.106-2.833C14.492 8.78 8.822 8.592 5.54 9.587c-.502.152-1.03-.135-1.182-.637-.152-.502.135-1.03.637-1.182 3.763-1.14 10.007-.923 14.07 1.493.45.268.6.847.332 1.298-.267.45-.847.6-1.298.332z"/>
      </svg>
    </div>

    <!-- Main Flex Container -->
    <div class="flex flex-col md:flex-row items-center gap-6">
      
      <!-- Podcast Cover Art -->
      <div class="w-32 h-32 md:w-36 md:h-36 shrink-0 shadow-lg relative overflow-hidden bg-zinc-800 rounded-sm">
        <img
          src="/podcast_cover.png"
          alt="Tech Latest Podcast Cover"
          class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500"
          loading="lazy"
        />
      </div>

      <!-- Information & Controls -->
      <div class="flex-1 w-full flex flex-col justify-between">
        
        <!-- Info Column -->
        <div class="mb-4 text-center md:text-left pr-0 md:pr-10">
          <h3 class="font-sans font-bold text-lg md:text-xl lg:text-2xl text-white leading-tight mb-2 hover:text-[#1DB954] transition-colors duration-150">
            <a href="#">Japan’s nuclear fusion startups innovate beyond energy</a>
          </h3>
          <p class="text-zinc-400 text-xs font-sans">
            May 19 · Tech Latest
          </p>
        </div>

        <!-- Action & Media Control Bar -->
        <div class="flex flex-col gap-4">
          <!-- Save on Spotify Button -->
          <div class="flex justify-center md:justify-start">
            <button class="inline-flex items-center gap-2 text-zinc-300 hover:text-white transition-colors duration-150 text-xs font-bold uppercase tracking-wider bg-zinc-900 border border-zinc-800 hover:border-zinc-700 py-1.5 px-3 rounded-full">
              <svg class="w-4 h-4 text-[#1DB954]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Save on Spotify
            </button>
          </div>

          <!-- Timeline & Play controls -->
          <div class="flex items-center gap-3 w-full">
            
            <!-- Replay 15s -->
            <button class="text-zinc-400 hover:text-white transition-colors duration-150 shrink-0" aria-label="Replay 15 seconds">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0019 16V8a1 1 0 00-1.6-.8l-5.334 4z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0011 16V8a1 1 0 00-1.6-.8l-5.334 4z"/>
              </svg>
            </button>

            <!-- Progress Bar -->
            <div class="flex-1 h-1.5 bg-zinc-700 rounded-full relative cursor-pointer group/progress">
              <div class="absolute top-0 left-0 h-full w-[35%] bg-[#1DB954] group-hover/progress:bg-[#1ed760] rounded-full"></div>
              <div class="absolute top-1/2 left-[35%] w-3 h-3 bg-white rounded-full -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover/progress:opacity-100 transition-opacity duration-150 shadow-md"></div>
            </div>

            <!-- Forward 15s -->
            <button class="text-zinc-400 hover:text-white transition-colors duration-150 shrink-0" aria-label="Forward 15 seconds">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.934 12.8a1 1 0 000-1.6L6.6 7.2A1 1 0 005 8v8a1 1 0 001.6.8l5.334-4z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.934 12.8a1 1 0 000-1.6l-5.334-4A1 1 0 0013 8v8a1 1 0 001.6.8l5.334-4z"/>
              </svg>
            </button>

            <!-- Duration -->
            <span class="text-zinc-400 text-xs font-sans select-none shrink-0">18:46</span>

            <!-- Actions menu ... -->
            <button class="text-zinc-400 hover:text-white transition-colors duration-150 shrink-0" aria-label="More actions">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M5 10a2 2 0 100 4 2 2 0 000-4zm7 0a2 2 0 100 4 2 2 0 000-4zm7 0a2 2 0 100 4 2 2 0 000-4z"/>
              </svg>
            </button>

            <!-- Play Button -->
            <button class="w-9 h-9 rounded-full bg-white text-black hover:scale-105 active:scale-95 transition-all duration-150 flex items-center justify-center shrink-0 shadow-md" aria-label="Play">
              <svg class="w-4 h-4 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>

          </div>

        </div>

      </div>

    </div>
  </div>
</section>

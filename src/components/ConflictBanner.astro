<section class="max-w-7xl mx-auto px-4 lg:px-6 py-4 md:py-6 mb-4" aria-label="Iran Conflict Coverage">
  <div class="flex flex-col md:flex-row bg-nk-navy text-white shadow-sm border-l-4 border-nk-red hover:shadow-md transition-shadow">
    
    <!-- Image Left -->
    <div class="w-full md:w-[35%] lg:w-[25%] relative aspect-21/9 md:aspect-auto bg-nk-navy-light">
      <img src="https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=800&q=80&auto=format&fit=crop" alt="Trading screens" class="absolute inset-0 w-full h-full object-cover opacity-70 mix-blend-luminosity" loading="lazy" />
    </div>
    
    <!-- Content Area -->
    <div class="w-full md:w-[65%] lg:w-[75%] flex flex-col md:flex-row">
      
      <!-- Text Details -->
      <div class="flex-1 p-5 md:p-6 lg:p-8 flex flex-col justify-center">
        <h2 class="text-xl md:text-2xl lg:text-3xl font-bold font-display leading-snug mb-2">
          How the Middle East crisis impacts Asia
        </h2>
        <p class="text-[0.85rem] md:text-sm text-nk-gray-300 font-sans mb-4 md:mb-5 max-w-xl">
          Our latest coverage of business, diplomacy and the economy after the U.S.-Israeli strikes
        </p>
        <a href="#" class="inline-flex items-center gap-2 font-bold text-[0.85rem] text-nk-red hover:text-white transition-colors font-sans w-max group uppercase tracking-wide">
          Discover more
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

      <!-- Right Side: Vertical Line + IRAN CONFLICT -->
      <div class="md:w-[160px] lg:w-[200px] shrink-0 flex items-center justify-center p-4 md:p-0 md:my-6 border-t md:border-t-0 md:border-l border-nk-gray-700 mx-5 md:mx-0">
        <span class="text-sm md:text-base lg:text-lg font-bold font-sans uppercase tracking-widest whitespace-nowrap text-center text-nk-gray-400">
          IRAN <br class="hidden md:block lg:hidden" />CONFLICT
        </span>
      </div>

    </div>
  </div>
</section>

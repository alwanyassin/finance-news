---
interface Props {
  title: string;
  href?: string;
  id?: string;
  size?: "lg" | "sm";
}

const { title, href, id, size = "lg" } = Astro.props;
---

<div class="section-header mb-0">
  <div class="flex items-center gap-3 flex-1">
    <span class={size === "sm" ? "shrink-0 w-1 h-5 md:h-6 bg-nk-red" : "shrink-0 w-1 h-6.5 md:h-8 bg-nk-red"}></span>
    <h2 id={id} class={size === "sm" ? "text-xl font-extrabold uppercase tracking-widest text-nk-gray-700 font-display" : "text-xl md:text-2xl font-extrabold uppercase tracking-widest text-nk-gray-700 font-display"}>
      {title}
    </h2>
    {
      href && (
        <a href={href} class="text-xs sm:text-sm font-semibold text-nk-gray-500 hover:text-nk-red uppercase tracking-wide transition-colors font-sans ml-auto">
          See All →
        </a>
      )
    }
  </div>
  <!-- <div class="flex-1 h-px bg-nk-gray-200 ml-3"></div> -->
</div>

---
interface Props {
  title: string;
  href?: string;
  id?: string;
}

const { title, href, id } = Astro.props;
---

<div class="section-header mb-0">
  <div class="flex items-center gap-3 flex-1">
    <span class="flex-shrink-0 w-1 h-5 bg-[var(--color-nk-red)]"></span>
    <h2
      id={id}
      class="text-[0.65rem] font-bold uppercase tracking-widest text-[var(--color-nk-gray-700)] font-sans"
    >
      {title}
    </h2>
    {href && (
      <a
        href={href}
        class="text-[0.6rem] font-semibold text-[var(--color-nk-gray-400)] hover:text-[var(--color-nk-red)] uppercase tracking-wide transition-colors font-sans ml-auto"
      >
        See All →
      </a>
    )}
  </div>
  <div class="flex-1 h-px bg-[var(--color-nk-gray-200)] ml-3"></div>
</div>

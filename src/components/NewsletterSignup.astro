---
<section class="bg-nk-navy text-white p-5" aria-labelledby="newsletter-heading">
  <h3 id="newsletter-heading" class="text-base font-bold mb-1 font-sans">Daily Briefing</h3>
  <p class="text-white/70 text-xs mb-4 font-sans leading-relaxed">The key stories from Asian markets and economics, delivered every morning.</p>
  <form class="space-y-2" aria-label="Newsletter signup form">
    <input
      type="email"
      placeholder="Your email address"
      class="w-full px-3 py-2.5 text-sm text-nk-gray-800 font-sans focus:outline-none"
      aria-label="Email address for Daily Briefing"
    />
    <button
      type="submit"
      class="w-full bg-nk-red text-white py-2.5 text-xs font-bold uppercase tracking-wide hover:bg-nk-red-dark transition-colors"
    >
      Sign Up Free
    </button>
  </form>
</section>

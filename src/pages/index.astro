---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { articles, getFeaturedArticles, getArticlesByCategory, timeAgo } from '../data/articles';

const featured = getFeaturedArticles();
const heroArticle = featured[0]!;
// Grid articles: rows 1+2 (6 cards) beneath the top featured story
const gridArticles = articles.slice(1, 7);
// Row 1 and Row 2 of the grid
const gridRow1 = gridArticles.slice(0, 3);
const gridRow2 = gridArticles.slice(3, 6);

const opinionArticles = getArticlesByCategory('opinion').slice(0, 1);
const marketArticles = getArticlesByCategory('markets').slice(0, 4);
const economyArticles = getArticlesByCategory('economy').slice(0, 3);
const techArticles = getArticlesByCategory('technology').slice(0, 3);
const latestArticles = articles.slice(0, 8);

// Editor's Picks and Headlines Data
const editorsPickBig = articles[7]!; // Example article for big card
const editorsPickSmall = articles.slice(8, 11);
const latestHeadlines = articles.slice(2, 8);
---

<Layout
  title="FinanceAsia — Asia-Pacific Financial Intelligence"
  description="Real-time financial news, market data, and expert analysis from across the Asia-Pacific region."
>
  <!-- ===== HERO SECTION: 3/4 Top Stories + 1/4 Widget ===== -->
  <section aria-label="Top stories">
    <div class="max-w-7xl mx-auto px-2 md:px-4 lg:px-6 py-0 md:py-4">
      <div class="flex flex-col lg:flex-row gap-0">

        <!-- ── LEFT 3/4: Top Stories ── -->
        <div class="flex-1 lg:pr-5 pb-5 lg:pb-0">

          <!-- Top featured article -->
          <article class="group px-2 pb-2 mb-2 border-b border-nk-gray-200" aria-label={heroArticle.title}>

            <!-- MOBILE: Gambar fullscreen di atas, teks di bawah -->
            <!-- DESKTOP: flex row — teks 50% kiri, gambar 50% kanan -->
            <div class="flex flex-col sm:flex-row sm:gap-5">

              <!-- Mobile-only image (full width, shown only on mobile) -->
              <div class="sm:hidden mb-3 -mx-4 overflow-hidden bg-nk-gray-200">
                <a href={`/article/${heroArticle.slug}`} tabindex="-1" aria-hidden="true">
                  <img
                    src={`${heroArticle.image}?w=800&q=85&auto=format&fit=crop`}
                    alt={heroArticle.imageAlt}
                    class="w-full h-[220px] object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="eager"
                    width="800"
                    height="220"
                  />
                </a>
              </div>

              <!-- Text column -->
              <div class="flex-1 min-w-0 sm:w-1/2 order-2 sm:order-1">
                <span class="category-tag mb-2 block">{heroArticle.category}</span>
                <h1
                  class="font-bold text-nk-gray-800 leading-tight mb-2 group-hover:text-nk-red transition-colors"
                  style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.1rem, 2vw, 1.45rem);"
                >
                  <a href={`/article/${heroArticle.slug}`}>{heroArticle.title}</a>
                </h1>
                <p class="text-nk-gray-600 text-sm leading-relaxed mb-3 hidden sm:block font-sans line-clamp-3">
                  {heroArticle.excerpt}
                </p>
                <!-- Sub-links (related bullets) -->
                <ul class="space-y-1.5 hidden md:block mb-3">
                  {gridRow1.slice(0, 2).map(a => (
                    <li class="flex items-start gap-2">
                      <span class="shrink-0 mt-1.5 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[7px] border-l-nk-red"></span>
                      <a
                        href={`/article/${a.slug}`}
                        class="text-xs text-nk-gray-700 hover:text-nk-red transition-colors leading-snug font-sans line-clamp-2"
                      >
                        {a.title}
                      </a>
                    </li>
                  ))}
                </ul>
                <!-- Mobile metadata (hidden on desktop) -->
                <div class="flex sm:hidden items-center justify-end gap-2 text-xs text-nk-gray-500 font-sans mt-3">
                  {heroArticle.premium && (
                    <span class="text-[0.6rem] font-bold text-nk-gold uppercase tracking-wide">Premium ·</span>
                  )}
                  <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>{timeAgo(heroArticle.publishedAt)}</span>
                  <span>·</span>
                  <span>{heroArticle.readTime} min read</span>
                </div>
              </div>

              <!-- Desktop image column (hidden on mobile, shown sm+) — 50% width -->
              <div class="hidden sm:block sm:w-1/2 shrink-0 self-start order-1 sm:order-2">
                <a href={`/article/${heroArticle.slug}`} tabindex="-1" aria-hidden="true" class="block overflow-hidden bg-nk-gray-200">
                  <img
                    src={`${heroArticle.image}?w=700&q=85&auto=format&fit=crop`}
                    alt={heroArticle.imageAlt}
                    class="w-full h-[180px] md:h-[210px] lg:h-[230px] object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="eager"
                    width="600"
                    height="230"
                  />
                </a>
                
                <!-- Desktop metadata (hidden on mobile, right-aligned) -->
                <div class="hidden sm:flex items-center justify-end gap-2 text-xs text-nk-gray-500 font-sans mt-2">
                  {heroArticle.premium && (
                    <span class="text-[0.6rem] font-bold text-nk-gold uppercase tracking-wide">Premium ·</span>
                  )}
                  <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>{timeAgo(heroArticle.publishedAt)}</span>
                  <span>·</span>
                  <span>{heroArticle.readTime} min read</span>
                </div>
              </div>

            </div>
          </article>

          <!-- 6 article cards: grid-cols-2 mobile (3 baris) → grid-cols-3 desktop (2 baris) -->
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-px bg-nk-gray-200">
            {[...gridRow1, ...gridRow2].map(article => (
              <article class="group bg-white p-2.5 sm:p-3 flex flex-col" aria-label={article.title}>
                <a href={`/article/${article.slug}`} tabindex="-1" aria-hidden="true"
                   class="block mb-2 overflow-hidden bg-nk-gray-200 aspect-video">
                  <img
                    src={`${article.image}?w=400&q=80&auto=format&fit=crop`}
                    alt={article.imageAlt}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    width="400"
                    height="225"
                  />
                </a>
                <span class="category-tag mb-1 block">{article.category}</span>
                <h3
                  class="text-base md:text-lg font-bold text-nk-gray-800 leading-snug mb-2 group-hover:text-nk-red transition-colors"
                  style="font-family: 'Playfair Display', Georgia, serif;"
                >
                  <a href={`/article/${article.slug}`}>{article.title}</a>
                </h3>
                <div class="flex items-center gap-1 text-[0.62rem] text-nk-gray-500 font-sans mt-auto">
                  <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>Updated {timeAgo(article.publishedAt)}</span>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- ── RIGHT 1/4: Widget Panel ── -->
        <aside class="lg:w-[260px] xl:w-[280px] shrink-0 lg:pl-0 pt-4 lg:pt-0 border-t border-nk-gray-200 lg:border-t-0" aria-label="Editorial widgets">
          <div class="h-full flex flex-col gap-2">

            <!-- Widget 1: (like "Policy Asia") -->
            <div class="flex-1 flex flex-col justify-center bg-nk-navy-light py-4">
              <h3 class="text-base font-bold text-nk-gray-100 mb-2.5 font-sans tracking-wide text-center uppercase">Asia Insights</h3>
              {(() => {
                const pick = articles.find(a => a.categorySlug === 'economy') ?? articles[1]!;
                return (
                  <article class="group" aria-label={pick.title}>
                    <p class="text-base font-semibold text-nk-gray-100 leading-snug mb-2 group-hover:text-nk-red transition-colors text-center"
                      style="font-family: 'Playfair Display', Georgia, serif;">
                      <a href={`/article/${pick.slug}`}>{pick.title}</a>
                    </p>
                    <a href={`/article/${pick.slug}`} tabindex="-1" aria-hidden="true" class="block overflow-hidden bg-nk-gray-200 relative">
                      <img
                        src={`${pick.image}?w=300&q=80&auto=format&fit=crop`}
                        alt={pick.imageAlt}
                        class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                        width="280"
                        height="160"
                      />
                    </a>
                    <p class="text-base text-nk-gray-100 font-sans mt-2 px-4 text-center line-clamp-3">{pick.excerpt}</p>
                  </article>
                );
              })()}
            </div>

            <hr class="border-t border-nk-gray-200 shrink-0 m-0" />

            <!-- Widget 2: Opinion -->
            <div class="flex-1 flex flex-col justify-center bg-nk-gray-200 p-4">
              {(() => {
                const op = opinionArticles[0] ?? articles[8]!;
                return (
                  <article class="group flex flex-col justify-center" aria-label={op.title}>
                    <span class="category-tag mb-1.5 block text-center">{op.category}</span>
                    <p class="text-base font-semibold text-nk-gray-800 leading-snug mb-2.5 group-hover:text-nk-red transition-colors text-center"
                      style="font-family: 'Playfair Display', Georgia, serif;">
                      <a href={`/article/${op.slug}`}>{op.title}</a>
                    </p>
                    <!-- Author row -->
                    <div class="flex items-center gap-2 justify-center">
                      <div class="w-7 h-7 rounded-full bg-nk-navy flex items-center justify-center text-white text-xs font-bold shrink-0">
                        {op.author.charAt(0)}
                      </div>
                      <span class="text-xs text-nk-gray-600 font-sans">{op.author}</span>
                    </div>
                  </article>
                );
              })()}
            </div>

            <hr class="border-t border-nk-gray-200 shrink-0 m-0" />

            <!-- Widget 3: Video / Featured Insight -->
            <div class="flex-1 flex flex-col justify-center">
              <div class="bg-nk-navy text-white p-0 overflow-hidden flex-1 flex flex-col justify-center relative min-h-[160px]">
                <p class="text-[0.6rem] font-bold uppercase tracking-widest text-white/60 text-center py-1.5 border-b border-white/10 font-sans relative z-10 bg-nk-navy">Video</p>
                {(() => {
                  const vid = articles[4] ?? articles[0]!;
                  return (
                    <a href={`/article/${vid.slug}`} class="group block relative flex-1 min-h-[100px]">
                      <img
                        src={`${vid.image}?w=300&q=80&auto=format&fit=crop`}
                        alt={vid.imageAlt}
                        class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
                        loading="lazy"
                      />
                      <!-- Play button overlay -->
                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/40 flex items-center justify-center group-hover:bg-white/30 transition-colors">
                          <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z"/>
                          </svg>
                        </div>
                      </div>
                    </a>
                  );
                })()}
                {(() => {
                  const vid = articles[4] ?? articles[0]!;
                  return (
                    <div class="p-2.5 relative z-10 bg-nk-navy">
                      <p class="text-base font-semibold text-white leading-snug text-center"
                        style="font-family: 'Playfair Display', Georgia, serif;">
                        <a href={`/article/${vid.slug}`} class="hover:text-nk-gold-light transition-colors">
                          FinanceAsia Film: {vid.title.split(':')[0]}
                        </a>
                      </p>
                    </div>
                  );
                })()}
              </div>
            </div>

          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Editor's Picks & Latest Headlines -->
  <section class="max-w-7xl mx-auto px-4 lg:px-6 py-10" aria-label="Editor's Picks and Latest Headlines">
    <div class="flex flex-col lg:flex-row gap-0">
      
      <!-- Left Column: Editor's Picks (matches Top Stories width) -->
      <div class="flex-1 lg:pr-5 pb-5 lg:pb-0">
        <h2 class="text-nk-navy font-display font-bold text-xl md:text-2xl uppercase tracking-wide mb-4 flex items-center gap-1">
          Editor's Picks
          <svg class="w-5 h-5 mt-0.5 text-nk-red" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </h2>

        <!-- Featured Big Card -->
        <article class="group relative flex flex-col md:flex-row bg-nk-navy text-white overflow-hidden mb-6 hover:shadow-lg transition-shadow duration-300 md:h-[230px]">
          <div class="p-6 flex-1 flex flex-col justify-center order-2 md:order-1 md:w-[50%] border-t-4 border-t-nk-red md:border-t-0 md:border-l-4 md:border-l-nk-red">
            <span class="text-[0.65rem] font-bold uppercase tracking-widest text-nk-gold-light mb-2 lg:mb-3 text-center md:text-left block font-sans">BIG IN ASIA</span>
            <h3 class="text-2xl md:text-[1.5rem] font-bold leading-tight mb-3 lg:mb-4 text-center md:text-left font-display group-hover:text-nk-gray-200 transition-colors">
              <a href={`/article/${editorsPickBig.slug}`} class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">{editorsPickBig.title}</a>
            </h3>
            <p class="text-[0.8rem] md:text-sm text-white/80 leading-relaxed text-center md:text-left font-sans mx-auto md:mx-0 line-clamp-2 md:line-clamp-2">
              {editorsPickBig.excerpt}
            </p>
          </div>
          <div class="order-1 md:order-2 md:w-[50%] relative aspect-video md:aspect-auto overflow-hidden bg-white">
            <img src={`${editorsPickBig.image}?w=800&q=85&auto=format&fit=crop`} alt={editorsPickBig.imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="800" height="450" />
          </div>
        </article>

        <!-- 3 Vertical Cards Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-px bg-nk-gray-200">
          {editorsPickSmall.map((article, index) => (
            <article class={`group bg-white p-2.5 sm:p-3 flex flex-col relative ${index === 2 ? 'col-span-2 sm:col-span-1 border-b border-nk-gray-200 sm:border-b-0' : ''}`} aria-label={article.title}>
              <a href={`/article/${article.slug}`} tabindex="-1" aria-hidden="true" class={`block mb-2 overflow-hidden bg-nk-gray-200 aspect-video ${index === 2 ? 'hidden sm:block' : ''}`}>
                <img src={`${article.image}?w=400&q=80&auto=format&fit=crop`} alt={article.imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" width="400" height="225" />
              </a>
              <span class="category-tag mb-1 block">{article.category}</span>
              <h3 class="text-base sm:text-lg font-bold text-nk-gray-800 leading-snug mb-2 group-hover:text-nk-red transition-colors" style="font-family: 'Playfair Display', Georgia, serif;">
                <a href={`/article/${article.slug}`} class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">{article.title}</a>
              </h3>
              <div class={`flex items-center gap-1 text-[0.62rem] text-nk-gray-500 font-sans mt-auto ${index === 2 ? 'hidden sm:flex' : ''}`}>
                <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>Updated {timeAgo(article.publishedAt)}</span>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Right Column: Latest Headlines (matches Widget Panel width) -->
      <div class="lg:w-[260px] xl:w-[280px] shrink-0 lg:pl-0 pt-8 lg:pt-0">
        <div class="bg-nk-gray-100 p-2 h-full border border-nk-gray-200">
          <h2 class="text-nk-navy font-display font-bold text-lg uppercase tracking-wide mb-0 pb-3 border-b-[3px] border-nk-red flex items-center gap-2">
            Latest Headlines
          </h2>
          
          <div class="flex flex-col divide-y divide-nk-gray-300">
            {latestHeadlines.map((article, index) => (
              <article class={`group relative ${index === latestHeadlines.length - 1 ? 'pt-3.5 pb-0' : 'py-3.5'}`}>
                <h4 class="font-body text-base font-medium text-nk-gray-800 leading-snug group-hover:text-nk-red transition-colors mb-2.5 line-clamp-2">
                  <a href={`/article/${article.slug}`} class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">{article.title}</a>
                </h4>
                <div class={`flex items-center text-[0.75rem] font-sans gap-1.5 ${index === 0 ? 'text-nk-breaking font-medium' : 'text-nk-gray-500'}`}>
                  <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <span>{index === 0 ? 'Updated ' : ''}{timeAgo(article.publishedAt)}</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ===== TRUMP-XI SUMMIT SECTION ===== -->
  <section class="max-w-7xl mx-auto px-4 lg:px-6 py-10" aria-label="Trump-Xi Summit">
    <div class="flex flex-col lg:flex-row gap-0">
      
      <!-- Left Column: Trump-Xi Content -->
      <div class="flex-1 lg:pr-5 pb-5 lg:pb-0">
        <h2 class="text-nk-navy font-display font-bold text-xl md:text-2xl uppercase tracking-wide mb-4 flex items-center gap-1">
          TRUMP-XI SUMMIT
          <svg class="w-5 h-5 mt-0.5 text-nk-red" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </h2>

        <!-- Featured Big Card -->
        <article class="group relative flex flex-col md:flex-row bg-nk-navy text-white overflow-hidden mb-6 hover:shadow-lg transition-shadow duration-300 md:h-[230px]">
          <div class="p-6 flex-1 flex flex-col justify-center order-2 md:order-1 md:w-[50%] border-t-4 border-t-nk-red md:border-t-0 md:border-l-4 md:border-l-nk-red">
            <span class="text-[0.65rem] font-bold uppercase tracking-widest text-nk-gold-light mb-2 lg:mb-3 text-center md:text-left block font-sans">COMMENT</span>
            <h3 class="text-2xl md:text-[1.5rem] font-bold leading-tight mb-3 lg:mb-4 text-center md:text-left font-display group-hover:text-nk-gray-200 transition-colors">
              <a href="#" class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">Brief US-China calm masks simmering anger and distrust</a>
            </h3>
            <p class="text-[0.8rem] md:text-sm text-white/80 leading-relaxed text-center md:text-left font-sans mx-auto md:mx-0 line-clamp-2 md:line-clamp-2">
              Trump's Beijing visit highlights both countries' dilemma in gaining upper hand
            </p>
          </div>
          <div class="order-1 md:order-2 md:w-[50%] relative aspect-video md:aspect-auto overflow-hidden bg-nk-gray-200">
            <img src="https://images.unsplash.com/photo-1529107386315-e1a2ed48a620?w=800&q=80&auto=format&fit=crop" alt="Trump and Xi" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" width="800" height="450" />
          </div>
        </article>

        <!-- 3 Vertical Cards Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-px bg-nk-gray-200">
          {[
            {
              title: "China says Xi and Trump agreed to spur trade by lowering some tariffs",
              image: "https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3",
              alt: "Trading floor screens",
            },
            {
              title: "Taiwan arms sale in focus as Trump insists he gave no ground to Xi",
              image: "https://images.unsplash.com/photo-1486325212027-8081e485255e",
              alt: "Skyline and construction",
            },
            {
              title: "Trump-Xi summit more symbol than substance, political experts say",
              image: "https://images.unsplash.com/photo-1559136555-9303baea8ebd",
              alt: "Financial district skyline",
            }
          ].map((card, index) => (
            <article class={`group bg-white p-2.5 sm:p-3 flex flex-col relative ${index === 2 ? 'col-span-2 sm:col-span-1 border-b border-nk-gray-200 sm:border-b-0' : ''}`} aria-label={card.title}>
              <a href="#" tabindex="-1" aria-hidden="true" class={`block mb-2 overflow-hidden bg-nk-gray-200 aspect-video ${index === 2 ? 'hidden sm:block' : ''}`}>
                <img src={`${card.image}?w=400&q=80&auto=format&fit=crop`} alt={card.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" width="400" height="225" />
              </a>
              <span class="category-tag mb-1 block">Trump-Xi Summit</span>
              <h3 class="text-base sm:text-lg font-bold text-nk-gray-800 leading-snug mb-2 group-hover:text-nk-red transition-colors" style="font-family: 'Playfair Display', Georgia, serif;">
                <a href="#" class="after:absolute after:inset-0 focus-visible:ring-2 focus-visible:ring-nk-red focus-visible:outline-none">{card.title}</a>
              </h3>
            </article>
          ))}
        </div>
      </div>

      <!-- Right Column: Promo Banner -->
      <div class="lg:w-[260px] xl:w-[280px] shrink-0 lg:pl-0 pt-8 lg:pt-0">
        <div class="bg-nk-navy-light w-full h-full flex flex-col items-center justify-between p-6 text-center text-white relative">
          <!-- Main Content -->
          <div class="w-full">
            <!-- Logo -->
            <div class="font-sans font-light text-2xl tracking-wide mb-8 flex items-center justify-center">
              FINANCE<span class="font-bold ml-1">Asia</span>
            </div>
            
            <!-- Phone Image (mockup composite) -->
            <div class="relative w-full max-w-[150px] mx-auto aspect-[1/1.6] mb-8">
              <img src="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?w=400&q=80&auto=format&fit=crop" alt="Mobile App screen 1" class="absolute inset-0 w-full h-full object-cover rounded-2xl shadow-2xl -rotate-6 border-[6px] border-white/90 z-10" loading="lazy" />
